// Lime_scooters clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace lime_scooters {

    entity Driver {
        id: string @unique
        name: string
        licensePlate: string
        rating: float
        online: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Rider {
        id: string @unique
        name: string
        phone: string
        rating: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Trip {
        id: string @unique
        riderId: string
        driverId: string
        origin: string
        destination: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Vehicle {
        id: string @unique
        driverId: string
        make: string
        model: string
        plate: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Fare {
        id: string @unique
        tripId: string
        base: float
        distanceKm: float
        total: float
        currency: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Rating {
        id: string @unique
        tripId: string
        byRole: string
        score: integer
        comment: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
